---
import type { TagEntry } from "@/features/tags/lib/tag-index";

interface Props {
  tags: TagEntry[];
  limit?: number;
}

const { tags, limit = 20 } = Astro.props;
const displayed = tags.slice(0, limit);

if (displayed.length === 0) return;

const maxCount = displayed[0]?.count ?? 1;

function getSizeClass(count: number): string {
  const ratio = count / maxCount;
  if (ratio > 0.6) return "text-sm font-medium";
  if (ratio > 0.3) return "text-xs";
  return "text-[length:var(--font-size-ui-2xs)]";
}
---

<div class="flex flex-wrap gap-2">
  {displayed.map((entry) => (
    <a
      href={`/tags/${entry.tag}`}
      class:list={[
        "inline-flex items-center gap-1 rounded-md bg-surface-hover px-2 py-1 text-muted-foreground transition-colors hover:bg-surface-active hover:text-foreground",
        getSizeClass(entry.count),
      ]}
    >
      #{entry.tag}
      <span class="text-[length:var(--font-size-ui-2xs)] opacity-60">{entry.count}</span>
    </a>
  ))}
</div>
