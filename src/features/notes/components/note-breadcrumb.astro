---
import type { CollectionEntry } from "astro:content";
import type { NoteResolver } from "@/lib/content-resolver";
import { createCollectionContentResolver } from "@/lib/content-resolver";
import { getNoteTitle } from "@/lib/notes";

interface Props {
  note: CollectionEntry<"notes">;
  notes: CollectionEntry<"notes">[];
  resolver?: NoteResolver;
}

const { note, notes, resolver: resolverProp } = Astro.props;
const resolver = resolverProp ?? createCollectionContentResolver(notes);
const title = getNoteTitle(note);

const rawParts = note.id.split("/");
const parts = rawParts.length === 1 ? ["notes", ...rawParts] : rawParts;
const folderParts = parts.slice(0, -1);

interface BreadcrumbItem {
  label: string;
  href?: string;
}

const crumbs: BreadcrumbItem[] = [{ label: "Home", href: "/" }];

for (const folder of folderParts) {
  const resolved = resolver.resolve(folder);
  const label = folder.charAt(0).toUpperCase() + folder.slice(1);
  crumbs.push(
    resolved.status === "resolved"
      ? { label, href: `/${resolved.entry.publicPath}` }
      : { label },
  );
}

crumbs.push({ label: title });
---

<nav aria-label="Breadcrumb" class="mb-4 flex items-center gap-1 overflow-x-auto text-sm text-muted-foreground">
  {crumbs.map((crumb, i) => (
    <>
      {i > 0 && (
        <svg class="size-3 shrink-0 text-muted-foreground/50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      )}
      {crumb.href ? (
        <a href={crumb.href} class="whitespace-nowrap transition-colors hover:text-foreground">
          {crumb.label}
        </a>
      ) : (
        <span class:list={["whitespace-nowrap", i === crumbs.length - 1 && "truncate text-foreground"]}>
          {crumb.label}
        </span>
      )}
    </>
  ))}
</nav>
