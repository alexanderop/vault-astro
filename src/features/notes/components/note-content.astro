---
import type { RenderResult } from "astro:content";
import { cn } from "@/lib/utils";
import { resolveContentClasses } from "@/features/notes/lib/content-classes";

interface Props {
  Content: RenderResult["Content"];
  cssclasses?: string[];
}

const { Content, cssclasses = [] } = Astro.props;
const contentClasses = resolveContentClasses(cssclasses);
---

<article class={cn("note-prose", ...contentClasses)}>
  <Content />
</article>
