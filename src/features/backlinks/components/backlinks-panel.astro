---
import type { Backlink } from "@/features/backlinks/lib/backlink-resolver";

interface Props {
  backlinks: Backlink[];
  variant?: "default" | "rail";
}

const { backlinks, variant = "default" } = Astro.props;
---

{backlinks.length > 0 && (
  <nav class:list={[
    variant === "rail"
      ? "rail-panel"
      : "mt-10 pt-6",
  ]} data-shortcut-list data-shortcut-target={variant === "rail" ? "backlinks" : undefined} tabindex={variant === "rail" ? "-1" : undefined}>
    <h2 class="rail-panel-title">
      <svg class="size-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 17 6-5-6-5"/></svg>
      Backlinks
    </h2>
    <ul class:list={[variant === "rail" ? "shell-list" : "flex flex-wrap gap-1.5"]}>
      {backlinks.map((link) => (
        <li>
          <a
            href={link.href}
            data-shortcut-item
            class:list={[
              variant === "rail"
                ? "shell-list-row block"
                : "inline-block rounded-sm px-2 py-0.5 text-sm text-muted-foreground transition-colors hover:bg-surface-hover hover:text-foreground",
            ]}
          >
            {link.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
