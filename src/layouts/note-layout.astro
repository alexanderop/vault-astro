---
import DocumentShell from "@/components/document-shell.astro";
import { SITE } from "@/config";
import type { CollectionEntry } from "astro:content";
import Sidebar from "@/features/navigation/components/sidebar.astro";
import { MobileNav } from "@/features/navigation/components/mobile-nav";
import { ThemeToggle } from "@/features/theme/components/theme-toggle";
import { SearchDialog } from "@/features/search/components/search-dialog";
import { ShortcutsProvider } from "@/features/shortcuts/components/shortcuts-provider";
import type { SearchEntry } from "@/features/search/lib/search-index";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  currentSlug?: string;
  wide?: boolean;
  notes: CollectionEntry<"notes">[];
  searchIndex: SearchEntry[];
  sourceUrl?: string;
}

const {
  title,
  description,
  canonicalPath,
  ogImage,
  currentSlug,
  wide = false,
  notes,
  searchIndex,
  sourceUrl,
} = Astro.props;

const hasAside = Astro.slots.has("aside");
---

<DocumentShell
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  includeMath={SITE.enableMath}
  includeMermaid={SITE.enableMermaid}
>
  <div class="shell-layout lg:flex" data-shortcut-target="top" data-source-url={sourceUrl}>
    <aside class="shell-desktop-sidebar">
      <Sidebar notes={notes} currentSlug={currentSlug} />
    </aside>
    <div class="shell-main">
      <header class="shell-header">
        <div class="shell-header-actions">
          <MobileNav notes={notes} currentSlug={currentSlug} client:load />
          <a href="/" class="text-sm font-semibold tracking-tight text-foreground/90 lg:hidden">Vault</a>
        </div>
        <div class="shell-header-actions justify-end">
          {SITE.showSearch && (
            <SearchDialog entries={searchIndex} sourceUrl={sourceUrl} client:load />
          )}
          {SITE.lightAndDarkMode && <ThemeToggle client:load />}
        </div>
        <ShortcutsProvider sourceUrl={sourceUrl} client:load />
      </header>
      <div
        class:list={[
          "shell-body",
          hasAside && "shell-body--with-rail",
        ]}
      >
        <main
          class:list={[
            "shell-content",
            wide ? "shell-content--wide" : "shell-content--default",
          ]}
        >
          <slot />
        </main>
        {hasAside && (
          <aside class="shell-rail" data-shortcut-target="right-rail" tabindex="-1">
            <div class="shell-rail-sticky">
              <slot name="aside" />
            </div>
          </aside>
        )}
      </div>
      {SITE.footer && (
        <footer class="shell-footer">
          {SITE.footer}
        </footer>
      )}
    </div>
  </div>
</DocumentShell>
