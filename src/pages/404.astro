---
import NoteLayout from "@/layouts/note-layout.astro";
import { getBuildSiteData } from "@/lib/build-site-data";
import { getNoteHref, getNoteTitle } from "@/lib/notes";
import { findSimilarNotes } from "@/lib/slug-similarity";

const { notes, resolver, searchIndex } = await getBuildSiteData();

const url = Astro.url.pathname.replace(/^\/|\/$/g, "");
const suggestions = findSimilarNotes(url, notes);
---

<NoteLayout title="Page Not Found" description="The page you're looking for doesn't exist." notes={notes} searchIndex={searchIndex}>
  <div class="flex flex-col items-center py-16 text-center">
    <p class="text-6xl font-bold text-muted-foreground/30">404</p>
    <h1 class="mt-4 text-2xl font-semibold tracking-tight">Page not found</h1>
    <p class="mt-2 text-sm text-muted-foreground">
      The page you're looking for doesn't exist or may have been moved.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
    >
      <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Back to home
    </a>
  </div>

  {suggestions.length > 0 && (
    <div class="mx-auto mt-10 max-w-md">
      <h2 class="mb-3 text-xs font-medium uppercase tracking-wider text-muted-foreground">
        Did you mean?
      </h2>
      <ul class="space-y-1">
        {suggestions.map((note) => (
          <li>
            <a
              href={getNoteHref(note, notes, resolver)}
              class="block rounded-md px-3 py-2 text-sm text-foreground/80 transition-colors hover:bg-surface-hover hover:text-foreground"
            >
              {getNoteTitle(note)}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</NoteLayout>
