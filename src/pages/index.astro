---
import { SITE } from "@/config";
import NoteLayout from "@/layouts/note-layout.astro";
import { getNoteHref, getNoteSummary, getNoteTitle, sortNotesByDateDesc } from "@/lib/notes";
import { loadSiteShellData } from "@/lib/site-shell";

const { notes, searchIndex } = await loadSiteShellData();
const sortedNotes = sortNotesByDateDesc(notes);
const displayedNotes = SITE.notesPerIndex > 0
  ? sortedNotes.slice(0, SITE.notesPerIndex)
  : sortedNotes;
---

<NoteLayout title="Home" description={SITE.description} canonicalPath="/" notes={notes} searchIndex={searchIndex}>
  <h1 class="mb-6 text-2xl font-semibold tracking-tight">Vault</h1>
  <ul class="shell-list" data-shortcut-list>
    {displayedNotes.map((note) => (
      <li>
        <a
          href={getNoteHref(note, notes)}
          data-shortcut-item
          class="block rounded-sm px-3 py-2.5 transition-colors hover:bg-surface-hover"
        >
          <span class="text-sm font-medium text-foreground/90">{getNoteTitle(note)}</span>
          <p class="mt-0.5 text-xs text-muted-foreground">{note.id}</p>
          {getNoteSummary(note) && (
            <p class="mt-0.5 line-clamp-1 text-xs text-muted-foreground">{getNoteSummary(note)}</p>
          )}
        </a>
      </li>
    ))}
  </ul>
</NoteLayout>
