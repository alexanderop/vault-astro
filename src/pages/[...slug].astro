---
import { render } from "astro:content";
import { SITE } from "@/config";
import NoteLayout from "@/layouts/note-layout.astro";
import NoteContent from "@/features/notes/components/note-content.astro";
import NoteHeader from "@/features/notes/components/note-header.astro";
import NoteBreadcrumb from "@/features/notes/components/note-breadcrumb.astro";
import BacklinksPanel from "@/features/backlinks/components/backlinks-panel.astro";
import { TableOfContents } from "@/features/notes/components/table-of-contents";
import { GraphView } from "@/features/graph/components/graph-view";
import { LinkPreviewProvider } from "@/features/link-preview/components/link-preview-provider";
import { StackedPagesProvider } from "@/features/stacked-pages/components/stacked-pages-provider";
import { getNoteTitle } from "@/lib/notes";
import { getBuildSiteData } from "@/lib/build-site-data";

export async function getStaticPaths() {
  const { backlinksMap, graphByNote, notes, resolver } = await getBuildSiteData();

  return notes.map((note) => {
    const resolvedNote = resolver.resolve(note.id);

    return {
      params: {
        slug: resolvedNote.status === "resolved" ? resolvedNote.entry.publicPath : note.id,
      },
      props: {
        note,
        backlinks: backlinksMap.get(note.id) ?? [],
        graphData: graphByNote?.get(note.id) ?? { nodes: [], edges: [] },
      },
    };
  });
}

const { note, backlinks, graphData } = Astro.props;
const { Content, headings } = await render(note);
const title = getNoteTitle(note);
const { notes, resolver, searchIndex } = await getBuildSiteData();
const resolvedNote = resolver.resolve(note.id);
const currentSlug = resolvedNote.status === "resolved" ? resolvedNote.entry.publicPath : note.id;
const canonicalPath = `/${currentSlug}`;
const description = note.data.description ?? note.data.summary ?? undefined;
const ogImage = typeof note.data.cover === "string"
  ? note.data.cover
  : typeof note.data.artwork === "string"
    ? note.data.artwork
    : undefined;
---

<NoteLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogImage={ogImage}
  currentSlug={currentSlug}
  wide
  notes={notes}
  searchIndex={searchIndex}
  sourceUrl={note.data.url ?? note.data.website}
>
  {SITE.showBreadcrumb && <NoteBreadcrumb note={note} notes={notes} resolver={resolver} />}
  <NoteHeader note={note} notes={notes} resolver={resolver} />
  <NoteContent Content={Content} cssclasses={note.data.cssclasses} />
  <LinkPreviewProvider
    entries={searchIndex.map(({ href, title, preview }) => ({ href, title, preview }))}
    client:load
  />
  {SITE.showStackedPages && (
    <StackedPagesProvider
      currentSlug={currentSlug}
      currentTitle={title}
      client:load
    />
  )}

  <Fragment slot="aside">
    {SITE.showGraph && (
      <GraphView
        data={graphData}
        currentSlug={note.id}
        title="Linked Notes"
        client:visible
      />
    )}
    {SITE.showTableOfContents && <TableOfContents headings={headings} client:load />}
    {SITE.showBacklinks && <BacklinksPanel backlinks={backlinks} variant="rail" />}
  </Fragment>
</NoteLayout>
