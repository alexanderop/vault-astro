{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "jsPlugins": [
    "./scripts/oxlint-plugin-config-imports.js",
    "./scripts/oxlint-plugin-feature-boundaries.js"
  ],
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "react",
    "react-perf",
    "jsx-a11y",
    "promise",
    "node",
    "vitest"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "eslint/no-unused-vars": "error",
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": "off",
    "jsx-a11y/no-autofocus": "off",
    "typescript/no-redundant-type-constituents": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/no-unnecessary-type-arguments": "warn",
    "typescript/no-misused-promises": "error",
    "typescript/restrict-template-expressions": "warn",
    "typescript/no-unnecessary-template-expression": "warn",
    "typescript/return-await": "error",
    "typescript/no-floating-promises": "error",
    "typescript/await-thenable": "error",
    "typescript/no-for-in-array": "error",
    "typescript/no-unnecessary-type-assertion": "warn",
    "typescript/no-unnecessary-condition": "warn",
    "typescript/consistent-type-imports": "warn",
    "typescript/no-import-type-side-effects": "warn",

    "react/exhaustive-deps": "warn",
    "react-perf/jsx-no-new-object-as-prop": "off",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "react-perf/jsx-no-new-array-as-prop": "off",

    "import/no-cycle": "error",
    "import/no-self-import": "error",
    "import/no-duplicates": "warn",

    "unicorn/no-instanceof-array": "error",
    "unicorn/prefer-node-protocol": "warn",
    "unicorn/no-thenable": "error",

    "vitest/no-conditional-tests": "error",
    "vitest/require-awaited-expect-poll": "error",

    "config-imports/no-alias-in-config-files": "error",
    "feature-boundaries/no-cross-feature-imports": "error"
  }
}
